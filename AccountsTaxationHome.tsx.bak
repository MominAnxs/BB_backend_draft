const onboarding = (() => {
  const total = onboardingList.length;
  const pending = onboardingList.filter(o => o.status === 'Pending').length;
  const done = onboardingList.filter(o => o.status === 'Done').length;
  const stuck = onboardingList.filter(o => o.status === 'Pending' && o.days > 7).length;
  const comp = onboardingList.filter(o => o.type === 'Compliance').length;
  const adv = onboardingList.filter(o => o.type === 'Advisory').length;
  const avgDays = Math.round(onboardingList.reduce((s, o) => s + o.days, 0) / total);
  return { total, pending, done, stuck, avgDays, comp, adv };
})();

const incidents = (() => {
  const total = incidentsList.length;
  const critical = incidentsList.filter(i => i.severity === 'Critical').length;
  const high = incidentsList.filter(i => i.severity === 'High').length;
  const medium = incidentsList.filter(i => i.severity === 'Medium').length;
  const comp = incidentsList.filter(i => i.type === 'Compliance').length;
  const adv = incidentsList.filter(i => i.type === 'Advisory').length;
  return { total, prevTotal: total + 2, critical, high, medium, comp, adv };
})();

const ratings = (() => {
  const total = ratingsList.length;
  const avg = +(ratingsList.reduce((s, r) => s + r.rating, 0) / total).toFixed(1);
  const compList = ratingsList.filter(r => r.type === 'Compliance');
  const advList = ratingsList.filter(r => r.type === 'Advisory');
  const compAvg = +(compList.reduce((s, r) => s + r.rating, 0) / compList.length).toFixed(1);
  const advAvg = +(advList.reduce((s, r) => s + r.rating, 0) / advList.length).toFixed(1);
  const lowCount = ratingsList.filter(r => r.rating <= 2).length;
  return { avg, prevAvg: +(avg - 0.1).toFixed(1), compAvg, advAvg, total, lowCount };
})();

