// ─── Headlines derived from row-level lists ─────────────────────────────────
// Every headline below is computed once from its source list so the card
// and the drawer table can never disagree as the data scales.

const activeClients = (() => {
  const total = activeClientList.length;
  const comp = activeClientList.filter(c => c.type === 'Compliance').length;
  const adv = activeClientList.filter(c => c.type === 'Advisory').length;
  return { total, comp, adv, change: 2, prevTotal: total - 2 };
})();

const revenue = (() => {
  const total = activeClientList.reduce((s, c) => s + c.revenue, 0);
  const comp = activeClientList.filter(c => c.type === 'Compliance').reduce((s, c) => s + c.revenue, 0);
  const adv = activeClientList.filter(c => c.type === 'Advisory').reduce((s, c) => s + c.revenue, 0);
  // prevTotal seeded from the Mar entry of revenueTrend so MoM-change pill
  // matches the chart shown in the drawer.
  const prevTotal = 15300000 + 7100000;
  const change = +(((total - prevTotal) / prevTotal) * 100).toFixed(1);
  return { total, comp, adv, prevTotal, change };
})();

const margin = (() => {
  const totalRev = activeClientList.reduce((s, c) => s + c.revenue, 0);
  const totalCost = activeClientList.reduce((s, c) => s + c.cost, 0);
  const compRev = activeClientList.filter(c => c.type === 'Compliance').reduce((s, c) => s + c.revenue, 0);
  const compCost = activeClientList.filter(c => c.type === 'Compliance').reduce((s, c) => s + c.cost, 0);
  const advRev = activeClientList.filter(c => c.type === 'Advisory').reduce((s, c) => s + c.revenue, 0);
  const advCost = activeClientList.filter(c => c.type === 'Advisory').reduce((s, c) => s + c.cost, 0);
  const rate = +(((totalRev - totalCost) / totalRev) * 100).toFixed(1);
  const compRate = +(((compRev - compCost) / compRev) * 100).toFixed(1);
  const advRate = +(((advRev - advCost) / advRev) * 100).toFixed(1);
  return { rate, compRate, advRate, prevRate: 43.0, target: 40.0 };
})();

// Compliance Status — A&T equivalent of PM's KSM Hit/Miss.
const complianceData = (() => {
  const total = activeClientList.length;
  const onTrack = activeClientList.filter(c => c.status === 'On Track').length;
  const behind = activeClientList.filter(c => c.status === 'Behind').length;
  const onTrackRate = total > 0 ? Math.round((onTrack / total) * 100) : 0;
  const compTotal = activeClientList.filter(c => c.type === 'Compliance').length;
  const compOnTrack = activeClientList.filter(c => c.type === 'Compliance' && c.status === 'On Track').length;
  const compBehind = compTotal - compOnTrack;
  const advTotal = activeClientList.filter(c => c.type === 'Advisory').length;
  const advOnTrack = activeClientList.filter(c => c.type === 'Advisory' && c.status === 'On Track').length;
  const advBehind = advTotal - advOnTrack;
  const target = 85;
  return { total, onTrack, behind, onTrackRate, compTotal, compOnTrack, compBehind, advTotal, advOnTrack, advBehind, target };
})();

